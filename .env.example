# Django core
SECRET_KEY=change-me-to-a-long-random-value
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
ALLOW_ALL_HOSTS=False

# Database (required)
# Render internal URL (recommended for Render service)
# DATABASE_URL=postgresql://<user>:<password>@<internal-host>/<database>
# Local/external URL example:
DATABASE_URL=postgresql://<user>:<password>@<external-host>/<database>?sslmode=require

# Optional integrations
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
GEMINI_API_KEY=

# Redis / Celery (optional)
REDIS_URL=redis://localhost:6379/0

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Cloud API (optional)
ACCESS_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=

# Security toggles
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
API_KEY=change-me-api-key

# Rate limit knobs (optional)
RATELIMIT_ENABLE=True
SECURITY_MAX_REQUESTS_PER_MINUTE=300
SECURITY_MAX_REQUESTS_PER_HOUR=15000
